---
const targetPath = '/en/';
const targetUrl = new URL(targetPath, Astro.site!).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting to the English homepage</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={targetUrl} />
    <meta http-equiv="refresh" content={`0;url=${targetUrl}`} />
  </head>
  <body>
    <p><a href={targetPath}>Continue to the English homepage</a>.</p>
  </body>
</html>
