---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Lang } from '@/utils/i18n';
import { DEFAULT_LANG, SUPPORTED_LANGS, stripLocalePrefix } from '@/utils/i18n';
import { t } from '@/utils/translations';
import { getLocalizedPost, getPostBySlug, postUrl } from '@/utils/posts';

interface Props {
  lang?: Lang;
  class?: string;
}

const { lang, class: className } = Astro.props as Props;
const resolvedLang = ((Astro.currentLocale as Lang | undefined) ??
  (lang as Lang | undefined) ??
  DEFAULT_LANG) as Lang;

const FLAG_MAP: Record<Lang, string> = {
  vi: '🇻🇳',
  en: '🇺🇸',
};
const currentFlag = FLAG_MAP[resolvedLang] ?? '🌐';
const currentPath = Astro.url.pathname;
const currentTail = `${Astro.url.search}${Astro.url.hash}`;
const localeAgnosticPath = stripLocalePrefix(currentPath);
const postMatch = currentPath.match(/^\/(vi|en)\/posts\/(.+?)\/?$/);
const currentPostSlug = postMatch?.[2];
const currentPost = currentPostSlug ? getPostBySlug(resolvedLang, currentPostSlug) : undefined;

function resolveLocaleHref(targetLang: Lang): string {
  if (targetLang === resolvedLang) {
    return `${getRelativeLocaleUrl(targetLang, localeAgnosticPath)}${currentTail}`;
  }

  if (currentPost) {
    const localized = getLocalizedPost(currentPost, targetLang);
    if (localized) return `${postUrl(localized, targetLang)}${currentTail}`;
    return `${getRelativeLocaleUrl(targetLang, '/posts/')}${currentTail}`;
  }

  return `${getRelativeLocaleUrl(targetLang, localeAgnosticPath)}${currentTail}`;
}
---

<details class={`relative ${className ?? ''}`.trim()} data-lang-root>
  <summary
    class="cursor-pointer rounded-md p-2 text-gray-700 select-none hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800"
  >
    <span aria-hidden="true">{currentFlag}</span>
    <span class="sr-only">{t(resolvedLang, 'language.switch')}</span>
  </summary>
  <div
    class="nav-dropdown absolute top-full left-1/2 z-50 mt-1 min-w-40 -translate-x-1/2 rounded-lg py-1.5 shadow-xl"
  >
    {
      SUPPORTED_LANGS.map((l) => (
        <a
          href={resolveLocaleHref(l)}
          class={`flex w-full items-center gap-2 rounded-sm px-2.5 py-1.5 text-sm transition-colors hover:bg-black/20 hover:text-gray-950 dark:hover:bg-white/15 dark:hover:text-white ${l === resolvedLang ? 'font-medium text-gray-950 dark:text-white' : 'text-gray-700 dark:text-gray-300'}`}
        >
          <span aria-hidden="true">{FLAG_MAP[l] ?? '🌐'}</span>
          <span>{t(l, 'language.name')}</span>
        </a>
      ))
    }
  </div>
</details>

<script>
  import { registerPageInit } from '@/utils/page-init';

  registerPageInit('languageSwitcher', () => {
    const langRoot = document.querySelector('[data-lang-root]');
    if (!langRoot) return;

    let closeTimeout: ReturnType<typeof setTimeout> | null = null;

    function handleMouseLeave() {
      closeTimeout = setTimeout(() => {
        if (langRoot instanceof HTMLDetailsElement) {
          langRoot.open = false;
        }
      }, 150);
    }

    function handleMouseEnter() {
      if (closeTimeout) {
        clearTimeout(closeTimeout);
        closeTimeout = null;
      }
    }

    langRoot.addEventListener('mouseleave', handleMouseLeave);
    langRoot.addEventListener('mouseenter', handleMouseEnter);

    return () => {
      langRoot.removeEventListener('mouseleave', handleMouseLeave);
      langRoot.removeEventListener('mouseenter', handleMouseEnter);
      if (closeTimeout) clearTimeout(closeTimeout);
    };
  });
</script>

<style>
  details[data-lang-root] > summary::-webkit-details-marker {
    display: none;
  }
  details[data-lang-root] > summary {
    list-style: none;
  }
</style>
