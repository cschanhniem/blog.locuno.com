---
import type { Lang } from '@/utils/i18n';
import { t, tOptional } from '@/utils/translations';
import FooterNav from '@/ui/FooterNav.astro';
import { Icon } from 'astro-icon/components';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  lang?: Lang;
  twitterHandle?: string;
  websiteUrl?: string;
  facebookUrl?: string;
  youtubeUrl?: string;
}

const resolvedLang = ((Astro.currentLocale as Lang | undefined) ??
  (Astro.props.lang as Lang | undefined) ??
  'en') as Lang;

const siteName = t(resolvedLang, 'site.name');

const twitterHandleRaw =
  (Astro.props.twitterHandle as string | undefined) ?? tOptional(resolvedLang, 'site.twitter.site');
const twitterHandle = String(twitterHandleRaw || '').replace(/^@/, '');
const websiteUrl =
  (Astro.props.websiteUrl as string | undefined) ?? tOptional(resolvedLang, 'site.links.website');
const facebookUrl =
  (Astro.props.facebookUrl as string | undefined) ?? tOptional(resolvedLang, 'site.links.facebook');
const youtubeUrl =
  (Astro.props.youtubeUrl as string | undefined) ?? tOptional(resolvedLang, 'site.links.youtube');

const socialLinks = [
  twitterHandle
    ? { href: `https://x.com/${twitterHandle}`, label: 'X', icon: 'lucide:x' }
    : undefined,
  websiteUrl ? { href: websiteUrl, label: 'Website', icon: 'lucide:globe' } : undefined,
  facebookUrl ? { href: facebookUrl, label: 'Facebook', icon: 'lucide:globe' } : undefined,
  youtubeUrl ? { href: youtubeUrl, label: 'YouTube', icon: 'lucide:globe' } : undefined,
].filter(Boolean) as Array<{ href: string; label: string; icon: string }>;
---

<footer class="footer-glass mb-6 w-full">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div class="flex flex-col md:col-span-1">
        <div>
          <a
            href={getRelativeLocaleUrl(resolvedLang, '/')}
            class="inline-flex items-center gap-2 text-xl font-semibold tracking-tight text-gray-950 transition-opacity hover:opacity-80 dark:text-gray-100"
          >
            <span class="text-xl text-gray-950 dark:text-gray-300">
              {siteName}
            </span>
          </a>
          {
            socialLinks.length > 0 && (
              <div class="mt-4 flex items-center gap-4 text-sm">
                {socialLinks.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 rounded-md p-2 text-gray-600 transition-all hover:bg-black/5 hover:text-gray-950 dark:text-gray-400 dark:hover:bg-white/10 dark:hover:text-white"
                  >
                    <span aria-hidden="true">
                      <Icon name={link.icon} class="h-5 w-5" />
                    </span>
                    <span class="sr-only">{link.label}</span>
                  </a>
                ))}
              </div>
            )
          }
        </div>

        {/* Desktop/Tablet: Copyright below social icons - pushed to bottom */}
        <div
          class="mt-auto hidden flex-row items-baseline gap-2 text-[10px] text-gray-500 md:flex dark:text-gray-400"
        >
          <span>
            &copy; {new Date().getFullYear()}
            {siteName}
          </span>
        </div>
      </div>

      <FooterNav lang={resolvedLang} />
    </div>

    {/* Mobile only: Copyright at bottom center */}
    <div
      class="mt-10 flex flex-row items-center justify-center gap-2 text-[10px] text-gray-500 md:hidden dark:text-gray-400"
    >
      <span>
        &copy; {new Date().getFullYear()}
        {siteName}
      </span>
    </div>
  </div>
</footer>
