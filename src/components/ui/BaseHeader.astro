---
import type { Lang } from '@/utils/i18n';
import { SUPPORTED_LANGS, DEFAULT_LANG, stripLocalePrefix } from '@/utils/i18n';
import { t, tOptional } from '@/utils/translations';
import {
  DEFAULT_OG_IMAGE,
  LANGUAGE_TAGS,
  OG_LOCALES,
  ORGANIZATION_LOGO,
  absoluteUrl,
  canonicalizeUrl,
  type BreadcrumbItem,
  type LanguageAlternate,
} from '@/utils/seo';
import { SEO } from 'astro-seo';
import { getAbsoluteLocaleUrl, getRelativeLocaleUrl } from 'astro:i18n';
import type { ImageMetadata } from 'astro';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  keywords?: string | string[];
  image?: string | ImageMetadata;
  imageAlt?: string;
  publishedTime?: string | Date | undefined;
  modifiedTime?: string | Date | undefined;
  canonical?: string;
  noindex?: boolean;
  authorName?: string;
  authorUrl?: string;
  section?: string;
  tags?: string[];
  languageAlternates?: LanguageAlternate[];
  xDefaultHref?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  lang: langProp = 'en',
  title,
  description,
  keywords,
  image,
  imageAlt,
  publishedTime,
  modifiedTime,
  canonical,
  noindex = false,
  authorName,
  authorUrl,
  section,
  tags = [],
  languageAlternates: providedLanguageAlternates,
  xDefaultHref: providedXDefaultHref,
  breadcrumbs = [],
} = Astro.props as Props;

const resolvedLang = ((Astro.currentLocale as Lang | undefined) ??
  (langProp as Lang) ??
  'en') as Lang;

const siteName = t(resolvedLang, 'site.name');
const titleTemplate = t(resolvedLang, 'site.titleTemplate');
const titleDefault = siteName;
const metaDescription = description ?? t(resolvedLang, 'site.description');
const twitterSite = tOptional(resolvedLang, 'site.twitter.site');
const twitterCreator = tOptional(resolvedLang, 'site.twitter.creator');
const keywordsStr = Array.isArray(keywords) ? keywords.join(', ') : keywords;

const rssPath = getRelativeLocaleUrl(resolvedLang, '/rss.xml').replace(/(\.xml)\/$/, '$1');
const rssURL = new URL(rssPath, Astro.site!).href;

const providedSrc =
  typeof image === 'string'
    ? image
    : image && typeof (image as any).src === 'string'
      ? (image as any).src
      : undefined;
const imageSrc = providedSrc || DEFAULT_OG_IMAGE;
const absImage = absoluteUrl(imageSrc, Astro.site!);

const absAuthorUrl = authorUrl ? absoluteUrl(authorUrl, Astro.site!) : undefined;

const isArticle = Boolean(publishedTime);
const languageTag = LANGUAGE_TAGS[resolvedLang] ?? resolvedLang;
const ogLocale = OG_LOCALES[resolvedLang] ?? 'en_US';
const ogAlternateLocales = SUPPORTED_LANGS.filter((l) => l !== resolvedLang).map(
  (l) => OG_LOCALES[l],
);

const localeAgnosticPath = stripLocalePrefix(Astro.url.pathname);
const generatedLanguageAlternates = SUPPORTED_LANGS.map((l) => ({
  hrefLang: LANGUAGE_TAGS[l] ?? l,
  href: getAbsoluteLocaleUrl(l, localeAgnosticPath),
}));
const languageAlternates = providedLanguageAlternates?.length
  ? providedLanguageAlternates.map((alternate) => ({
      hrefLang: alternate.hrefLang,
      href: canonicalizeUrl(alternate.href, Astro.site!),
    }))
  : generatedLanguageAlternates.map((alternate) => ({
      hrefLang: alternate.hrefLang,
      href: canonicalizeUrl(alternate.href, Astro.site!),
    }));
const xDefaultHref = canonicalizeUrl(
  providedXDefaultHref || getAbsoluteLocaleUrl(DEFAULT_LANG, localeAgnosticPath),
  Astro.site!,
);

const rawCanonical = canonical || new URL(Astro.url.pathname, Astro.site!).href;
const finalCanonical = canonicalizeUrl(rawCanonical, Astro.site!);

const siteUrl = canonicalizeUrl('/', Astro.site!);
const organizationId = `${siteUrl}#organization`;
const websiteId = `${siteUrl}#website`;
const webpageId = `${finalCanonical}#webpage`;
const breadcrumbId = `${finalCanonical}#breadcrumb`;
const logoUrl = absoluteUrl(ORGANIZATION_LOGO, Astro.site!);
const normalizedBreadcrumbs = breadcrumbs
  .filter((item) => item.name && item.item)
  .map((item) => ({
    name: item.name,
    item: canonicalizeUrl(item.item, Astro.site!),
  }));

const seoProps: any = {
  title: title ?? undefined,
  titleTemplate,
  titleDefault,
  description: metaDescription,
  canonical: finalCanonical,
  noindex: !!noindex,
  languageAlternates: [...languageAlternates, { hrefLang: 'x-default', href: xDefaultHref }],
  openGraph: {
    basic: {
      title: title || siteName,
      type: isArticle ? 'article' : 'website',
      image: absImage,
      url: finalCanonical,
    },
    optional: {
      description: metaDescription,
      locale: ogLocale,
      localeAlternate: ogAlternateLocales,
      siteName: siteName,
    },
    ...(isArticle
      ? {
          article: {
            ...(publishedTime ? { publishedTime: new Date(publishedTime).toISOString() } : {}),
            ...(modifiedTime ? { modifiedTime: new Date(modifiedTime).toISOString() } : {}),
            ...(absAuthorUrl || authorName
              ? { authors: [absAuthorUrl ?? (authorName as string)] }
              : {}),
            ...(section ? { section } : {}),
            ...(Array.isArray(tags) ? { tags } : {}),
          },
        }
      : {}),
    image: {
      ...(imageAlt ? { alt: imageAlt } : {}),
    },
  },
  twitter: {
    card: absImage ? 'summary_large_image' : 'summary',
    ...(twitterSite ? { site: twitterSite } : {}),
    ...(twitterCreator ? { creator: twitterCreator } : {}),
    title: title || siteName,
    description: metaDescription,
    image: absImage,
    ...(imageAlt ? { imageAlt } : {}),
  },
  extend: {
    link: [
      { rel: 'icon', type: 'image/png', sizes: '32x32', href: '/favicon-32x32.png' },
      { rel: 'icon', type: 'image/png', sizes: '16x16', href: '/favicon-16x16.png' },
      { rel: 'shortcut icon', href: '/favicon.ico' },
      { rel: 'apple-touch-icon', sizes: '180x180', href: '/apple-touch-icon.png' },
      { rel: 'sitemap', href: '/sitemap.xml' },
      { rel: 'alternate', type: 'application/rss+xml', title: siteName, href: rssURL },
    ],
    meta: [
      ...(keywordsStr ? [{ name: 'keywords', content: keywordsStr }] : []),
      ...(authorName ? [{ name: 'author', content: authorName }] : []),
      { name: 'generator', content: Astro.generator },
    ],
  },
} as const;
---

<script is:inline>
  try {
    const stored = localStorage.getItem('theme');
    if (stored === 'light') {
      document.documentElement.classList.remove('dark');
      document.documentElement.setAttribute('data-theme', 'light');
    } else if (stored === 'dark') {
      document.documentElement.classList.add('dark');
      document.documentElement.setAttribute('data-theme', 'dark');
    } else {
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.classList.toggle('dark', prefersDark);
      document.documentElement.setAttribute('data-theme', 'system');
    }
  } catch (e) {}
</script>

<SEO {...seoProps} />

{
  (() => {
    const canonicalURL = finalCanonical;
    const pageTitle = title ? titleTemplate.replace('%s', title) : siteName;
    const pageNode: any = {
      '@id': webpageId,
      '@type': isArticle ? 'BlogPosting' : 'WebPage',
      inLanguage: languageTag,
      name: pageTitle,
      url: canonicalURL,
      description: metaDescription,
      isPartOf: { '@id': websiteId },
      mainEntityOfPage: { '@id': webpageId },
    };
    if (absImage) {
      pageNode.image = absImage;
      pageNode.primaryImageOfPage = { '@type': 'ImageObject', url: absImage };
    }
    if (normalizedBreadcrumbs.length) pageNode.breadcrumb = { '@id': breadcrumbId };
    if (isArticle) {
      if (title) pageNode.headline = title;
      if (publishedTime) pageNode.datePublished = new Date(publishedTime).toISOString();
      if (modifiedTime) pageNode.dateModified = new Date(modifiedTime).toISOString();
      pageNode.publisher = { '@id': organizationId };
      pageNode.isAccessibleForFree = true;
      if (authorName)
        pageNode.author = {
          '@type': 'Person',
          name: authorName,
          ...(absAuthorUrl ? { url: absAuthorUrl } : {}),
        };
      if (section) pageNode.articleSection = section;
      if (Array.isArray(tags) && tags.length) {
        pageNode.keywords = tags.join(', ');
        pageNode.about = tags.map((tag) => ({ '@type': 'Thing', name: tag }));
      }
    }
    const graph: any[] = [
      {
        '@type': 'Organization',
        '@id': organizationId,
        name: siteName,
        url: siteUrl,
        logo: { '@type': 'ImageObject', url: logoUrl },
      },
      {
        '@type': 'WebSite',
        '@id': websiteId,
        name: siteName,
        url: siteUrl,
        inLanguage: languageTag,
        publisher: { '@id': organizationId },
        potentialAction: {
          '@type': 'SearchAction',
          target: `${canonicalizeUrl(`/${resolvedLang}/search/`, Astro.site!)}?q={search_term_string}`,
          'query-input': 'required name=search_term_string',
        },
      },
      pageNode,
    ];
    if (normalizedBreadcrumbs.length) {
      graph.push({
        '@type': 'BreadcrumbList',
        '@id': breadcrumbId,
        itemListElement: normalizedBreadcrumbs.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.name,
          item: item.item,
        })),
      });
    }
    return (
      <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify({ '@context': 'https://schema.org', '@graph': graph })}
      />
    );
  })()
}
